{
  "info": {
    "_postman_id": "3d0487ff-f2e8-4fc3-bf29-1fa0f9027b6e",
    "name": "Parking - Admin Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/admin/auth/login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Token exists', function () { pm.expect(json?.data?.token).to.be.a('string'); });",
              "if (json?.data?.token) pm.environment.set('admin_token', json.data.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": "{{base_url}}/api/admin/auth/login"
      }
    },
    {
      "name": "POST /api/admin/auth/owners",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('owner_email')) {",
              "  pm.environment.set('owner_email', 'owner+' + Date.now() + '@example.com');",
              "}",
              "if (!pm.environment.get('owner_name')) pm.environment.set('owner_name', 'Parking Owner');",
              "if (!pm.environment.get('owner_phone')) pm.environment.set('owner_phone', '+212600000002');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{owner_name}}\",\n  \"email\": \"{{owner_email}}\",\n  \"phone\": \"{{owner_phone}}\",\n  \"password\": \"{{owner_password}}\",\n  \"password_confirmation\": \"{{owner_password_confirmation}}\"\n}"
        },
        "url": "{{base_url}}/api/admin/auth/owners"
      }
    },
    {
      "name": "GET /api/admin/auth/me",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "url": "{{base_url}}/api/admin/auth/me"
      }
    },
    {
      "name": "POST /api/admin/auth/logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.environment.unset('admin_token');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "url": "{{base_url}}/api/admin/auth/logout"
      }
    }
  ]
}
