    {
      "name": "User Auth",
      "item": [
        {
          "name": "POST /api/user/auth/register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('user_email')) {",
                  "  pm.environment.set('user_email', 'user+' + Date.now() + '@example.com');",
                  "}",
                  "pm.environment.set('user_name', 'Test User');",
                  "pm.environment.set('user_phone', '+212600000001');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.environment.set('user_token', json.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{user_name}}\",\n  \"email\": \"{{user_email}}\",\n  \"phone\": \"{{user_phone}}\",\n  \"password\": \"{{user_password}}\",\n  \"password_confirmation\": \"{{user_password_confirmation}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/user/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "user",
